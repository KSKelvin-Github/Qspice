      «text (-150,-150) 0.681 11 0 0x1000000 -1 -1 "Vpp=<10>;peak-peak voltage"»
      «text (-150,-250) 0.681 11 0 0x1000000 -1 -1 "freq=<100K>;frequency"»
      «text (-150,-350) 0.681 11 0 0x1000000 -1 -1 "duty=<0.5>"»
      «text (-150,-450) 0.681 11 0 0x1000000 -1 -1 "DCoffset=<0>"»
      «text (-150,-550) 0.681 11 0 0x1000000 -1 -1 "Tstart=<0> ;Starting time, 0 before this time"»
      «text (-150,-650) 0.681 11 0 0x1000000 -1 -1 "PhaseDelay=<10>;phase in degree"»
      «text (-150,-750) 0.681 11 2 0x1000000 -1 -1 "Trise=<0> ;rise time"»
      «text (-150,-850) 0.681 11 2 0x1000000 -1 -1 "Tfall=<0> ;fall time"»
